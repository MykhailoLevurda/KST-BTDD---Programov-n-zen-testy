<FindBugsFilter>
    <!-- JPA entity vrstvy: předávání asociací a kolekcí je očekávané chování,
         proto ignorujeme EI_EXPOSE_REP / EI_EXPOSE_REP2 na těchto třídách. -->
    <Match>
        <Class name="cz.kst.btdd.persistence.EntityRental"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="cz.kst.btdd.persistence.EntityRental"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Class name="cz.kst.btdd.persistence.EntityTool"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="cz.kst.btdd.persistence.EntityUser"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
</FindBugsFilter>
